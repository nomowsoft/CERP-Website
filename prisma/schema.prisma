generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  email         String?        @unique
  name          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  password      String
  phone         String?        @unique
  role          Role           @default(ADMIN)
  charityName   String?
  subscriptions Subscription[]
}

model Subscription {
  id                Int                   @id @default(autoincrement())
  userId            Int
  fullName          String
  email             String
  phone             String
  charityRegisterNo String
  licenseFile       String
  domainType        DomainType
  domainName        String?
  paymentMethod     PaymentMethod
  cardNumber        String?
  cardHolderName    String?
  cardExpiryDate    String?
  cardCVV           String?
  bankReceipt       String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  status            Status
  approvalDate      DateTime?
  expiryDate        DateTime?
  packageId         Int?
  payments          Payment[]
  package           Package?              @relation(fields: [packageId], references: [id])
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  instanceUrl       String?
  services          Service[]             @relation("ServiceToSubscription")
  systems           System[]              @relation("SystemToSubscription")
  requests          SubscriptionRequest[]

  @@index([userId])
}

model Package {
  id             Int                   @id @default(autoincrement())
  image          Bytes?
  name           String
  type           PackageType
  description    String
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  currency       String                @default("SAR")
  description_ar String                @default("")
  description_en String                @default("")
  name_ar        String                @default("")
  name_en        String                @default("")
  price          Decimal               @default(0)
  features       PackageFeature[]
  subscriptions  Subscription[]
  requests       SubscriptionRequest[]
  systems        System[]              @relation("PackageToSystem")
}

model SubscriptionRequest {
  id             Int           @id @default(autoincrement())
  subscriptionId Int
  type           RequestType
  packageId      Int?
  paymentMethod  PaymentMethod
  bankReceipt    String?
  status         RequestStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  licenseFile    String?
  package        Package?      @relation(fields: [packageId], references: [id])
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  services       Service[]     @relation("ServiceToSubscriptionRequest")
  systems        System[]      @relation("SystemToSubscriptionRequest")
}

model SystemSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Payment {
  id             Int           @id @default(autoincrement())
  subscriptionId Int
  amount         Decimal
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  checkoutId     String?       @unique
  transactionId  String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model PackageFeature {
  id        Int     @id @default(autoincrement())
  text      String
  packageId Int
  text_ar   String  @default("")
  text_en   String  @default("")
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
}

model Service {
  id             Int                   @id @default(autoincrement())
  image          Bytes?
  name           String
  description    String
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  currency       String                @default("SAR")
  description_ar String                @default("")
  description_en String                @default("")
  name_ar        String                @default("")
  name_en        String                @default("")
  price          Decimal               @default(0)
  contents       ServiceType[]
  subscriptions  Subscription[]        @relation("ServiceToSubscription")
  requests       SubscriptionRequest[] @relation("ServiceToSubscriptionRequest")
}

model ServiceType {
  id        Int     @id @default(autoincrement())
  name      String
  serviceId Int
  name_ar   String  @default("")
  name_en   String  @default("")
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model System {
  id             Int       @id @default(autoincrement())
  name           String
  name_ar        String    @default("")
  name_en        String    @default("")
  description    String    @default("")
  description_ar String    @default("")
  description_en String    @default("")
  icon           Bytes?
  price          Decimal   @default(0)
  modules        String[]  @default([])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  packages       Package[]             @relation("PackageToSystem")
  subscriptions  Subscription[]        @relation("SystemToSubscription")
  requests       SubscriptionRequest[] @relation("SystemToSubscriptionRequest")
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum DomainType {
  SUBDOMAIN
  CUSTOM_DOMAIN
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentMethod {
  ONLINE
  BANK
}

enum Status {
  DRAFT
  PROGRES
  DONE
  CANCEL
}

enum PackageType {
  STARTER
  BUSINESS
  ENTERPRISE
}

enum RequestType {
  RENEW
  UPGRADE
  ADD_SYSTEM
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}
